# Copie este arquivo para ".env" (sem o ".example") e preencha
# com os dados do seu projeto Supabase.
#
# Onde encontrar:
# 1. Acesse supabase.com e abra seu projeto
# 2. Vá em "Project Settings" (ícone de engrenagem) > "API"
# 3. Copie "Project URL" e cole em VITE_SUPABASE_URL
# 4. Copie "anon public" key e cole em VITE_SUPABASE_ANON_KEY

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui
